    <!-- About (FIXED #30, #31) -->
    <string name="about_title">About</string>
    <string name="about_what_title">What is the E521.39?</string>
    <string name="about_what_body">The Elmos E521.39 is a high-precision automotive ADC designed for resistor-ladder switch decoding. A single analog input reliably distinguishes 17+ switch positions on a two-wheeler handlebar — replacing a thick wiring harness with a single signal line.</string>
    <string name="about_features_title">Key features</string>
    <string name="about_feature_1">17 distinguishable switch states</string>
    <string name="about_feature_2">Resistor-ladder ADC decoding</string>
    <string name="about_feature_3">BLE telemetry to this dashboard</string>
    <string name="about_feature_4">Automotive-grade noise rejection</string>
    <string name="about_howto_title">How to use this demo</string>
    <string name="about_howto_1">Power the demonstrator board.</string>
    <string name="about_howto_2">Tap the connection bar and grant Bluetooth permissions.</string>
    <string name="about_howto_3">Toggle the handlebar switch and watch the dashboard update in real time.</string>
    <string name="about_howto_4">No hardware? Tap the demo button to see a simulated cycle.</string>
    <string name="about_contact_title">Contact &amp; support</string>
    <string name="about_contact_body">Built by SSAY for Elmos product demonstrations.\nFor questions, contact your Elmos representative.</string>
    <string name="about_developed_by">Developed by SSAY</string>
