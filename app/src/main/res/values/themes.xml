<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base activity theme: kept simple; Compose handles the actual UI styling. -->
    <style name="Theme.SwitchDemonstrator" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        FIXED #47: SplashScreen API theme. Shown on cold start and replaced by the
        Compose UI after the first frame. Uses the dark brand background and the
        Elmos logo as the centred icon.
    -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/elmos_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.SwitchDemonstrator</item>
    </style>
</resources>
